    {
      "rule_id": "UW-007",
      "domain": "underwriting",
      "description": "高血压（2级及以上，收缩压≥160或舒张压≥100），医疗险拒保/除外",
      "if": {
        "conditions": [
          {
            "field": "disease",
            "operator": "equals",
            "value": "高血压"
          },
