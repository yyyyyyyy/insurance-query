      "rule_id": "UW-009",
      "domain": "underwriting",
      "description": "糖尿病前期（糖耐量异常）未确诊，定期寿险可标准承保",
      "if": {
        "conditions": [
          {
            "field": "disease",
            "operator": "equals",
            "value": "糖耐量异常"
          },
          {
            "field": "diagnosed",
            "operator": "equals",
            "value": "false"
          },
          {
            "field": "fbg",
            "operator": "lt",
            "value": 7.0
          },
          {
            "field": "hba1c",
            "operator": "lt",
            "value": 6.5
          },
          {
            "field": "product_type",
            "operator": "equals",
