            "field": "disease",
            "operator": "equals",
            "value": "高血压"
          },
          {
            "field": "severity",
            "operator": "equals",
            "value": "grade_1"
          },
          {
            "field": "systolic_bp",
            "operator": "lte",
            "value": 160
          },
          {
            "field": "diastolic_bp",
            "operator": "lte",
            "value": 100
          },
          {
            "field": "product_type",
