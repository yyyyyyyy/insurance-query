            "field": "disease_subtype",
            "operator": "equals",
            "value": "甲状腺癌"
          },
          {
            "field": "tnm_stage",
            "operator": "equals",
            "value": "I"
          },
          {
            "field": "years_since_surgery",
            "operator": "gte",
            "value": 1
          },
          {
            "field": "recurrence",
            "operator": "equals",
            "value": "false"
          }
        ]
      },
      "then": {
        "decision": "standard_accept",
        "action": "standard_underwriting_with_post_op_note"
