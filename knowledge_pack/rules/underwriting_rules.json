  "rules": [
    {
      "rule_id": "UW-001",
      "domain": "underwriting",
      "description": "投保人故意或因重大过失未如实告知，保险人有权解除合同",
      "if": {
        "conditions": [
          {
            "field": "health_disclosure",
            "operator": "equals",
            "value": "false"
          },
          {
            "field": "materiality",
            "operator": "equals",
            "value": "sufficient_to_affect_decision"
          }
        ]
      },
      "then": {
        "decision": "reject",
        "action": "decline_and_void_contract"
      },
      "confidence": "HIGH",
      "source": "regulatory_document",
      "source_ref": "REG003-第十六条",
      "ontology_mapping": {
        "entities": [
          "ENT-RL004",
          "ENT-R003"
        ],
        "relations": [
          "defines",
          "regulates"
        ]
      },
      "process_mapping": {
        "process": "underwriting_lifecycle",
        "node": "health_declaration",
        "trigger_event": "E_honesty_fail"
      }
    },
    {
      "rule_id": "UW-002",
      "domain": "underwriting",
      "description": "合同成立超过两年，保险人不得以未如实告知为由解除合同",
      "if": {
        "conditions": [
          {
            "field": "health_disclosure",
            "operator": "equals",
            "value": "false"
          },
          {
            "field": "contract_age_years",
            "operator": "gte",
            "value": 2
          }
        ]
      },
      "then": {
        "decision": "standard_accept",
        "action": "waive_misrepresentation"
      },
      "confidence": "HIGH",
      "source": "regulatory_document",
      "source_ref": "REG003-第十六条",
      "ontology_mapping": {
        "entities": [
          "ENT-RL004",
          "ENT-R003"
        ],
        "relations": [
          "defines"
        ]
      },
      "process_mapping": {
        "process": "underwriting_lifecycle",
        "node": "health_declaration",
        "trigger_event": "E_honesty_pass"
      }
    },
    {
      "rule_id": "UW-003",
      "domain": "underwriting",
      "description": "确诊恶性肿瘤（甲状腺癌TNM-I期及以下除外），重疾险、医疗险一律拒保",
      "if": {
        "conditions": [
          {
            "field": "disease",
            "operator": "equals",
            "value": "恶性肿瘤"
          },
          {
            "field": "severity",
            "operator": "in",
            "value": [
              "重度",
              "中期",
              "晚期"
            ]
          },
          {
            "field": "tnm_stage",
            "operator": "gte",
            "value": "II"
          }
        ]
      },
      "then": {
        "decision": "reject",
        "action": "permanent_decline"
      },
      "confidence": "HIGH",
      "source": "underwriting_manual",
      "source_ref": "UW_MANUAL-MALIGNANCY-01",
      "ontology_mapping": {
        "entities": [
          "ENT-D001",
          "ENT-P001",
          "ENT-P002",
          "ENT-P003"
        ],
        "relations": [
          "covers",
          "applies_to"
        ]
      },
      "process_mapping": {
        "process": "underwriting_lifecycle",
        "node": "risk_assessment",
        "trigger_event": "E_assess_risk"
      }
    },
    {
