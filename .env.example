# DeepSeek LLM
# IMPORTANT: This is a template. Copy to .env and fill in your real API key.
# The .env file MUST NOT be committed to version control.
# Rotate your API key periodically via https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# LLM plugin (auto-enabled when DEEPSEEK_API_KEY is set; set LLM_ENABLED=false to disable)
LLM_ENABLED=true
LLM_INTENT_ENABLED=true
LLM_ANSWER_ENABLED=true
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
